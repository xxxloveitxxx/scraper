{
  "manifest_version": 3,
  "name": "ReplyzeAI Home Services Scraper",
  "version": "2.2",
  "description": "Scrape Google Maps & business websites for home service leads (ICP targeted)",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://maps.google.com/*",
    "https://*.google.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/*", "https://maps.google.com/*", "https://*.google.com/maps/*", "<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}